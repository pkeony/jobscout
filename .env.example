# Gemini API Key (서버 기본값 — 사용자가 자체 키를 입력하지 않을 때 사용)
GOOGLE_API_KEY=

# Anthropic API Key (eval LLM-as-a-judge 전용 — Claude Haiku 4.5로 매칭 품질 평가)
ANTHROPIC_API_KEY=

# Supabase (Phase 2A+)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# 토스페이먼츠 (Phase 2C) — test_ck_/test_sk_ 테스트 키 권장
NEXT_PUBLIC_TOSS_CLIENT_KEY=
TOSS_SECRET_KEY=
# 웹훅 서명 검증용 (미설정 시 webhook 엔드포인트는 서명 검증 스킵)
TOSS_WEBHOOK_SECRET=

# 크론 엔드포인트 (/api/cron/*) 호출 인증 — `openssl rand -hex 32` 로 생성
CRON_SECRET=
